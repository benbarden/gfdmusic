{% extends 'layouts/base.twig' %}

{% block layout_welcome %}
    <div class="p-4 p-md-5 mb-4 gfd-bg-welcome">
        <div class="gfd-welcome-text col-md-6">
            <h1>About</h1>
            <p>
                The home of Ben Barden's music.
            </p>
        </div>
    </div>
{% endblock layout_welcome %}

{% block page_body %}

    <h2 class="pb-4 mb-4 border-bottom">
        Welcome to GFD Music
    </h2>

    <article class="blog-post">

        <p>
            GFD Music is the home for several artist projects, each with its own sound and identity.
        </p>

        <div class="d-flex mb-4">
            <img src="/assets/artist-logos/castles-of-the-underground-800x800.jpg" alt="Castles of the Underground" class="me-4" style="width: 150px; height: 150px;">
            <div>
                <h3>Castles of the Underground</h3>
                <p>
                    Dance and trance music. The current focus.
                </p>
                <p>
                    Good dance music takes you on a journey - hidden worlds, late nights, that feeling of being transported
                    somewhere else entirely. That's what Castles of the Underground is about.
                </p>
                <p>
                    <a href="/castles-of-the-underground">View artist profile</a>
                </p>
            </div>
        </div>

        <div class="d-flex mb-4">
            <img src="/assets/artist-logos/gfd-800x800.jpg" alt="GFD" class="me-4" style="width: 150px; height: 150px;">
            <div>
                <h3>GFD</h3>
                <p>
                    Catchy, upbeat, funky music. The original project, with releases dating back to 2020.
                </p>
                <p>
                    The name comes from "greenfield development" - starting fresh. After years of unfinished tracks,
                    GFD was about finally releasing music properly.
                </p>
                <p>
                    <a href="/gfd">View artist profile</a>
                </p>
            </div>
        </div>

        <div class="d-flex mb-4">
            <img src="/assets/artist-logos/roads-to-atlantis-800x800.jpg" alt="Roads to Atlantis" class="me-4" style="width: 150px; height: 150px;">
            <div>
                <h3>Roads to Atlantis</h3>
                <p>
                    Experimental and videogame-style music. The niche stuff.
                </p>
                <p>
                    This draws from albums written between 2005-2009 - soundtracks for games and films that don't exist.
                    Available on Bandcamp and Soundcloud.
                </p>
                <p>
                    <a href="/roads-to-atlantis">View artist profile</a>
                </p>
            </div>
        </div>

        <h3>Who's behind this?</h3>

        <p>
            All projects are the work of Ben Barden.
        </p>
        <p>
            <a href="https://threads.net/@gfdmusic">Follow on Threads</a>
        </p>

    </article>

{% endblock page_body %}
